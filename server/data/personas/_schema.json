{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Persona",
  "type": "object",
  "required": ["name", "nickname", "model", "personality", "writing_style", "topics"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Internal persona identifier (must match filename)"
    },
    "nickname": {
      "type": "string",
      "description": "Display name used in the community"
    },
    "model": {
      "type": "string",
      "description": "Ollama model (llama3, gemma2, mistral, phi3, qwen2)"
    },
    "activity_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 5,
      "description": "Actions per set (1=quiet, 10=hyperactive)"
    },
    "recent_scope": {
      "type": "integer",
      "minimum": 1,
      "default": 10,
      "description": "Interact with the last N posts/comments only"
    },
    "personality": {
      "type": "string",
      "description": "Personality description for prompt generation"
    },
    "writing_style": {
      "type": "string",
      "description": "Writing style instructions for the LLM"
    },
    "topics": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Topics this persona is interested in"
    }
  }
}
